# Backend environment variables.
# Copy this file to a `.env` at the PROJECT ROOT (one level up from backend/)
# and fill in your real values. The real .env is gitignored - never commit it.

# Supabase Postgres connection string (URI form).
# Supabase dashboard: Project Settings > Database > Connection string > "URI".
#
# Direct connection (IPv6, port 5432):
#   DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.fgvgrjeeenetksxvepxh.supabase.co:5432/postgres
#
# Recommended for hosted backends - Session/Transaction pooler (IPv4, port 6543):
#   DATABASE_URL=postgresql://postgres.fgvgrjeeenetksxvepxh:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=
