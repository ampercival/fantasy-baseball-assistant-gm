# Frontend environment variables (Vite).
# Copy to .env.local for local overrides. Do NOT commit real .env files.

# Backend API origin for production builds (GitHub Pages).
# Leave UNSET for local dev so requests stay relative and use the Vite dev proxy.
# Example once the FastAPI backend is hosted (Phase 2):
# VITE_API_URL=https://fantasy-baseball-assistant-gm.onrender.com

# Supabase project URL + publishable (anon) key, used for reads ported to Edge Functions
# (e.g. the aggregate board). The anon key is safe to expose and is protected by RLS.
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
